# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BASECAMP_CLIENT_ID and BASECAMP_CLIENT_SECRET 
# Get these by creating an OAuth application in Basecamp Integration settings.
BASECAMP_CLIENT_ID="YOUR_BASECAMP_CLIENT_ID"
BASECAMP_CLIENT_SECRET="YOUR_BASECAMP_CLIENT_SECRET"
