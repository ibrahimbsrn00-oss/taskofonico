{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Taskofonico",
  "version": "0.1.0",
  "identifier": "com.taskofonico.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Taskofonico",
        "width": 1340,
        "height": 900,
        "minWidth": 1240,
        "minHeight": 820,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ibrahimbsrn00-oss/taskofonico/releases/latest/download/latest.json"
      ]
    }
  }
}
